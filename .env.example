# =============================================================================
# The Mom Drop — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust for your environment.
#   cp .env.example .env
# =============================================================================

# --- Server ---
PORT=3000
NODE_ENV=development

# --- Domain ---
# Set this to your production URL when deploying.
# Soft launch: https://mom-drop.com
PUBLIC_BASE_URL=http://localhost:3000

# --- Database ---
# Absolute path to the SQLite database file.
# Default (fallback): /home/team/shared/app.db
# DATABASE_PATH=/home/team/shared/app.db
# DB_PATH=/home/team/shared/app.db

# --- Amazon Associates ---
# Your Amazon Associates tracking tag.
# Owner provided tag: shopwitshelby-20
AMAZON_ASSOCIATE_TAG=shopwitshelby-20

# --- Channel Flags ---
# Enable SMS dispatch. Defaults to false (email-only MVP).
# To enable: ENABLE_SMS=true
ENABLE_SMS=false

# --- Resend (Transactional Email) ---
# API key from https://resend.com/api-keys
# Required for real email sending. Without it, emails are logged to backend/logs/notifications.log
# RESEND_API_KEY=re_xxxxxxxxxxxx

# Sender identity — displayed to email recipients
EMAIL_FROM_NAME=The Mom Drop
EMAIL_FROM_ADDRESS=hello@mom-drop.com

# Safety gate: set to true only after DNS/email auth is configured
# Default is false — emails are logged but not sent
# EMAIL_SENDING_ENABLED=false

# --- Email Testing ---
# Optional: recipient for the test-email script (or pass as CLI arg)
# TEST_EMAIL_RECIPIENT=you@example.com
