# =============================================================================
# The Mom Drop — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust for your environment.
#   cp .env.example .env
# =============================================================================

# --- Server ---
PORT=3000
NODE_ENV=development

# --- Domain ---
# Set this to your production URL when deploying.
# Soft launch: https://mom-drop.com
PUBLIC_BASE_URL=http://localhost:3000

# --- Database ---
# Absolute path to the SQLite database file.
# Default (fallback): /home/team/shared/app.db
# DATABASE_PATH=/home/team/shared/app.db
# DB_PATH=/home/team/shared/app.db

# --- Amazon Associates ---
# Your Amazon Associates tracking tag.
# Owner provided tag: shopwitshelby-20
AMAZON_ASSOCIATE_TAG=shopwitshelby-20

# --- Channel Flags ---
# Enable SMS dispatch. Defaults to false (email-only MVP).
# To enable: ENABLE_SMS=true
ENABLE_SMS=false
